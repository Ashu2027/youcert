# =====================================================================
# YOUCERT — Environment Variables
# Updated: 2026-02-24 (Cloudflare Migration)
#
# LOCAL DEVELOPMENT: Copy to .env and fill in values.
# PRODUCTION: Set all of these as Cloudflare Workers Secrets:
#   wrangler secret put SECRET_NAME
# =====================================================================

# =====================================================================
# ENVIRONMENT
# =====================================================================
IS_DEVELOPMENT=true                     # 'true' for local, 'false' in Cloudflare
SERVICE_URL=http://localhost:5000       # Public URL of your deployed service

# =====================================================================
# FLASK
# =====================================================================
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-flask-secret-key-here

# =====================================================================
# ENCRYPTION (Fernet — replaces Cloud KMS)
# =====================================================================
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your-fernet-key-here

# =====================================================================
# DATABASE
# Option A: Local MySQL (default for development)
# Option B: TiDB Cloud Serverless (free tier — https://tidbcloud.com/)
# =====================================================================

# --- OPTION A: LOCAL MYSQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-db-password

# --- OPTION B: TIDB CLOUD SERVERLESS ---
# Get connection string from: TiDB Cloud → Connect → Connect with MySQL
# MYSQL_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
# MYSQL_USER=your-username.root
# MYSQL_PASSWORD=your-tidb-password
# TIDB_CA_PATH=C:\path\to\isrgrootx1.pem   # Windows only: DL CA from TiDB dashboard

# =====================================================================
# GOOGLE OAUTH 2.0 (user login — unchanged from GCP setup)
# =====================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# =====================================================================
# GOOGLE YOUTUBE DATA API v3
# =====================================================================
# Get from: https://console.developers.google.com/
YOUTUBE_API_KEY=your-youtube-api-key

# =====================================================================
# GEMINI AI (direct REST API — no Vertex AI / no GCP project needed)
# =====================================================================
# Get API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite       # Optional — defaults to gemini-2.5-flash-lite

# =====================================================================
# CLOUDFLARE ACCOUNT (for Queues REST API dispatch)
# =====================================================================
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token   # Needs Queues:Write permission

# =====================================================================
# CLOUDFLARE R2 STORAGE (S3-compatible — replaces GCS)
# =====================================================================
# Create bucket in Cloudflare Dashboard → R2 → Create Bucket
R2_BUCKET_NAME=youcert-buc-main
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id       # R2 → Manage R2 API Tokens
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Optional: Set a custom public domain for the bucket (enables faster public URLs)
R2_PUBLIC_URL=https://files.yourdomain.com

# =====================================================================
# CLOUDFLARE QUEUES (replaces Cloud Tasks)
# =====================================================================
# Queue IDs from Cloudflare Dashboard → Workers & Pages → Queues
VIDEO_PROCESSING_QUEUE_ID=your-video-processing-queue-id
CHUNK_GENERATION_QUEUE_ID=your-chunk-generation-queue-id

# =====================================================================
# PAYMENT GATEWAY
# =====================================================================
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# =====================================================================
# ADVANCED LOCAL OVERRIDES (Optional)
# =====================================================================
# PORT=8080                                  # Override the default WSGI localhost port (8080)
# GEVENT_SUPPORT=True                        # locally simulate cloudflare concurrent greenlets
# R2_PUBLIC_URL=https://files.youcert.com     # mapped custom domain for R2 storage

# =====================================================================
# REMOVED — No longer needed (GCP-only variables)
# =====================================================================
# GOOGLE_PROJECT_ID          → Not needed (no GCP project)
# GOOGLE_CLOUD_REGION        → Not needed
# GOOGLE_APPLICATION_CREDENTIALS → Not needed (no service account)
# MYSQL_UNIX_SOCKET          → Replaced by MYSQL_HOST/PORT (TCP)
# GCS_BUCKET_NAME            → Replaced by R2_BUCKET_NAME
# CLOUD_TASKS_LOCATION       → Replaced by CLOUDFLARE_ACCOUNT_ID
# VIDEO_PROCESSING_QUEUE     → Replaced by VIDEO_PROCESSING_QUEUE_ID
# CHUNK_GENERATION_QUEUE     → Replaced by CHUNK_GENERATION_QUEUE_ID
# USE_GOOGLE_SECRETS         → Removed (secrets are always env vars now)
# KMS_KEY_NAME               → Removed (Fernet replaces KMS)
# VERTEX_AI_LOCATION         → Removed (Gemini API is global)
