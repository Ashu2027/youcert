# ==============================================================================
# YOUCERT .gitignore - Security & Environment Files
# ==============================================================================

# ==============================================================================
# CRITICAL: Environment & Secrets (NEVER COMMIT THESE!)
# ==============================================================================
.env
.env.*
!.env.example

# Node dependencies
node_modules/

# Google Cloud Service Account Keys (CRITICAL!)
*.json
!package.json
!package-lock.json
!tsconfig.json

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
.venv/
venv/
ENV/
env/
.virtualenv/

# ==============================================================================
# Flask
# ==============================================================================
instance/
.webassets-cache
.flask_session/

# ==============================================================================
# User Uploads & Storage (Don't commit user data!)
# ==============================================================================
uploads/
static/uploads/
storage/

# ==============================================================================
# IDE & Editors
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ==============================================================================
# Testing
# ==============================================================================
.pytest_cache/
.coverage
htmlcov/
*.cover

# ==============================================================================
# Logs
# ==============================================================================
*.log
logs/

# ==============================================================================
# Database
# ==============================================================================
*.db
*.sqlite
*.sqlite3

# ==============================================================================
# Temporary Files
# ==============================================================================
*.tmp
*.temp
.cache/

# ==============================================================================
# OS
# ==============================================================================
Thumbs.db
.DS_Store
